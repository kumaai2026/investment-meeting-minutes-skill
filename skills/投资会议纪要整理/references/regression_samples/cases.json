{
  "cases": [
    {
      "name": "subagent 任一触发规则文档检查",
      "mode": "reference_subagent_dispatch",
      "check": "text_contains",
      "file": "../subagent_guide.md",
      "required_terms": ["只要满足任一高风险条件", "triggered_by", "skipped_reason", "不要等到所有条件同时满足"]
    },
    {
      "name": "输出合约标题逃逸与时间戳精度文档检查",
      "mode": "reference_output_contract",
      "check": "text_contains",
      "file": "../output_contract.md",
      "required_terms": ["契约外逃逸标题", "sentence/phrase 级 anchor", "segment/chunk/minute 级范围"]
    },
    {
      "name": "文本-only 样例",
      "mode": "text_only",
      "source_mode": "document",
      "file": "text_only.md",
      "required_terms": ["中芯国际", "订单能见度改善", "没有加仓"]
    },
    {
      "name": "音频转写-only 样例",
      "mode": "audio_only",
      "file": "audio_only.md",
      "verification_file": "audio_only.verification.json",
      "require_verification": true,
      "require_audio_timestamps": true,
      "timestamp_index_file": "timestamp_index_sentence.json",
      "timestamp_index_require_reliable": true,
      "required_terms": ["北美算力", "15万元一吨", "十七八倍"]
    },
    {
      "name": "verification sidecar 缺字段负例",
      "mode": "audio_bad_verification_negative",
      "file": "audio_only.md",
      "verification_file": "audio_bad_verification.verification.json",
      "require_verification": true,
      "expect_fail": true,
      "required_error_terms": ["缺少字段"]
    },
    {
      "name": "音频+文稿 样例",
      "mode": "audio_text",
      "file": "audio_text.md",
      "require_audio_timestamps": true,
      "required_terms": ["光模块", "800G", "存疑：英伟达供货节奏"]
    },
    {
      "name": "音频无可靠时间戳样例",
      "mode": "audio_unavailable_timestamp",
      "source_mode": "audio",
      "timestamp_mode": "unavailable",
      "file": "audio_unavailable_timestamp.md",
      "required_terms": ["没有可靠时间戳 anchor", "OCS"]
    },
    {
      "name": "低精度时间戳误用负例",
      "mode": "audio_low_precision_timestamp_negative",
      "file": "audio_low_precision_timestamp_negative.md",
      "require_audio_timestamps": true,
      "timestamp_index_file": "timestamp_index_low_precision_negative.json",
      "timestamp_index_require_reliable": true,
      "expect_fail": true,
      "required_error_terms": ["低精度 chunk 不得作为可靠存疑时间戳"]
    },
    {
      "name": "短 SenseVoice VAD segment 存疑时间戳样例",
      "mode": "timestamp_index_sensevoice_vad_segment",
      "file": "audio_only.md",
      "timestamp_index_file": "timestamp_index_sensevoice_vad_segment.json",
      "timestamp_index_require_reliable": true,
      "required_terms": ["北美算力"]
    },
    {
      "name": "过长 SenseVoice VAD segment 负例",
      "mode": "timestamp_index_sensevoice_vad_segment_long_negative",
      "file": "audio_only.md",
      "timestamp_index_file": "timestamp_index_sensevoice_vad_segment_long_negative.json",
      "timestamp_index_require_reliable": true,
      "expect_fail": true,
      "required_error_terms": ["duration_ms"]
    },
    {
      "name": "多人复盘会类型样例",
      "mode": "meeting_type_review",
      "source_mode": "document",
      "file": "review_meeting.md",
      "required_terms": ["多人复盘会", "真实顺序", "中际旭创", "我今天还是围绕", "我没有减仓", "不想改成别的说法"]
